# EVMBench checkout. The CLI also falls back to common local yudai-swe-agent paths.
YUDAI_EVMBENCH_PROJECT_DIR=/absolute/path/to/evmbench

# Model selection. Use a LiteLLM-compatible name.
YUDAI_EVMBENCH_MODEL=openrouter/openai/gpt-5.1

# Set the key for your selected provider.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Modal and private registry access, when needed.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_AUDIT_IMAGE_REPO=
DOCKER_USERNAME=
DOCKER_PASSWORD=

# Forest sizing defaults.
YUDAI_FOREST_BRANCHES_PER_TREE=2
YUDAI_FOREST_MAX_TREE_ROLES=4
YUDAI_FOREST_WORKER_CONCURRENCY=4

# Optional runtime knobs.
YUDAI_REBUILD_BASE=false
MSWEA_COST_TRACKING=default
